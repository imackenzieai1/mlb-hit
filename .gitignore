# --- envs / caches / OS noise ---
.venv/
.env
__pycache__/
*.pyc
.ipynb_checkpoints/
.DS_Store
logs/
db/

# --- raw data caches (large, ephemeral, regenerated by the cron) ---
data/raw/
data/clean/
data/modeling/
data/output/
models/*.joblib

# --- BUT we DO ship these, so the cloud runner can score the slate ---
# Whitelist the trained model + feature inputs the workflow needs.
# Active production: xgb_v5_recal (Optuna joint search winner, 2026-04-29).
# Prior production / rollback: xgb_v3_recal at Filter E v2.1 — kept shipped
# so `--legacy-v2-1` works on the cron runner without manual artifact pulls.
!models/xgb_v5.joblib
!models/xgb_v5.json
!models/xgb_v5_recal.joblib
!models/xgb_v3.joblib
!models/xgb_v3.json
!models/xgb_v3_recal.joblib
# Optuna search outputs — kept so eval_optuna_winner.py can run on any
# checkout without re-running the (~30 min) joint search.
!models/xgb_optuna.joblib
!models/xgb_optuna_winner.json
!data/modeling/
data/modeling/*
!data/modeling/player_game_features.parquet

# Cleaned data parquets that score_today.py reads at runtime. These are
# small (10 MB total) and slow to regenerate, so we ship them with the repo
# and let the workflow update boxscores_* + game_starters_* in place daily.
# Anything under data/clean/ NOT listed here stays gitignored (e.g. the
# `daily_boxscores/` and `game_starters_cache/` working-cache dirs, the
# `player_name_lookup_cache.parquet` resolver cache).
!data/clean/
data/clean/*
data/clean/daily_boxscores/
data/clean/game_starters_cache/
!data/clean/boxscores_*.parquet
!data/clean/batter_season_stats.parquet
!data/clean/pitcher_season_stats.parquet
!data/clean/batter_rolling.parquet
!data/clean/pitcher_rolling.parquet
!data/clean/game_starters_*.parquet
!data/clean/players.parquet
!data/clean/bullpen_features.parquet
# Legacy: this matched nothing in the current schema (files are named
# `batter_season_stats.parquet`, not `season_stats_batter.parquet`) but
# kept here in case anything ever lands at the canonical name.
!data/clean/season_stats_*.parquet

# Recommendations directory: the workflow commits today's CSV back here
# so the dashboard + email digest can read it.
!data/output/
data/output/*
!data/output/recommendations/
!data/output/recommendations/*.csv
!data/output/backtests/
!data/output/backtests/*.csv
